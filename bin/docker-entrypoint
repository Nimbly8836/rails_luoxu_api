#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the production process manager, web server, or job runner,
# create or migrate existing databases before boot.
if { [ "$1" = "./bin/rails" ] && [ "$2" = "server" ]; } || \
   { [ "$1" = "./bin/thrust" ] && [ "$2" = "./bin/rails" ] && [ "$3" = "server" ]; } || \
   { [ "$1" = "bundle" ] && [ "$2" = "exec" ] && [ "$3" = "foreman" ] && [ "$4" = "start" ]; } || \
   { [ "$1" = "./bin/jobs" ] || [ "$1" = "bin/jobs" ]; }; then
  ./bin/rails db:prepare
fi

exec "${@}"
