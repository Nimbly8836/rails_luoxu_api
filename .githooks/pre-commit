#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

ruby_files=()
while IFS= read -r -d '' path; do
  case "$path" in
    *.rb|Gemfile|Rakefile|config.ru)
      ruby_files+=("$path")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ "${#ruby_files[@]}" -eq 0 ]]; then
  exit 0
fi

partially_staged=()
while IFS= read -r -d '' path; do
  partially_staged+=("$path")
done < <(git diff --name-only -z -- "${ruby_files[@]}")

formattable_files=()
for path in "${ruby_files[@]}"; do
  skip=false
  for partial in "${partially_staged[@]}"; do
    if [[ "$path" == "$partial" ]]; then
      skip=true
      break
    fi
  done

  if [[ "$skip" == false ]]; then
    formattable_files+=("$path")
  fi
done

if [[ "${#partially_staged[@]}" -gt 0 ]]; then
  printf 'pre-commit: skipping auto-format for partially staged Ruby files:\n' >&2
  printf '  %s\n' "${partially_staged[@]}" >&2
fi

if [[ "${#formattable_files[@]}" -eq 0 ]]; then
  exit 0
fi

if [[ ! -x "bin/rubocop" ]]; then
  printf 'pre-commit: bin/rubocop is missing or not executable.\n' >&2
  exit 1
fi

printf 'pre-commit: formatting staged Ruby files with RuboCop...\n'
bin/rubocop -A --force-exclusion "${formattable_files[@]}"
git add -- "${formattable_files[@]}"
